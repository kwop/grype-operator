{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Vulnerabilities by Severity",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(grype_operator_vulnerabilities_total{severity=\"Critical\"}) or vector(0)",
          "legendFormat": "Critical",
          "refId": "A"
        },
        {
          "expr": "sum(grype_operator_vulnerabilities_total{severity=\"High\"}) or vector(0)",
          "legendFormat": "High",
          "refId": "B"
        },
        {
          "expr": "sum(grype_operator_vulnerabilities_total{severity=\"Medium\"}) or vector(0)",
          "legendFormat": "Medium",
          "refId": "C"
        },
        {
          "expr": "sum(grype_operator_vulnerabilities_total{severity=\"Low\"}) or vector(0)",
          "legendFormat": "Low",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "High" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Medium" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Low" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Vulnerabilities by Namespace",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (namespace) (grype_operator_vulnerabilities_total{severity=~\"Critical|High\"})",
          "legendFormat": "{{ namespace }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "title": "Top Vulnerable Images (Critical + High)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "topk(20, sum by (image) (grype_operator_vulnerabilities_total{severity=~\"Critical|High\"}))",
          "legendFormat": "{{ image }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "image": "Image", "Value": "Critical+High CVEs" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Scan Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(grype_operator_scans_total{status=\"completed\"}[5m]) * 60",
          "legendFormat": "Completed/min",
          "refId": "A"
        },
        {
          "expr": "rate(grype_operator_scans_total{status=\"failed\"}[5m]) * 60",
          "legendFormat": "Failed/min",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed/min" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Scan Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(grype_operator_scan_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 duration",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(grype_operator_scan_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 duration",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "Operator Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "grype_operator_images_scanned",
          "legendFormat": "Images Tracked",
          "refId": "A"
        },
        {
          "expr": "grype_operator_cache_size",
          "legendFormat": "Cache Size",
          "refId": "B"
        },
        {
          "expr": "time() - grype_operator_db_last_update_timestamp",
          "legendFormat": "DB Age (seconds)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "DB Age (seconds)" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 43200 },
                    { "color": "red", "value": 86400 }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["grype", "security", "vulnerabilities"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(grype_operator_vulnerabilities_total, namespace)",
        "name": "namespace",
        "type": "query",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Grype Operator - Vulnerability Dashboard",
  "uid": "grype-operator"
}
